{
  "name": "debezium-orders-outbox",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "dbz_user",
    "database.password": "__INJECTED_AT_APPLY_TIME__",
    "database.dbname": "orders",
    "database.server.name": "dbz.orders",
    "topic.prefix": "dbz.orders",
    "slot.name": "dbz_orders_domain_slot",
    "publication.name": "dbz_publication",
    "plugin.name": "pgoutput",
    "table.include.list": "public.outbox_events",
    "snapshot.mode": "never",
    "tombstones.on.delete": "false",
    "transforms": "outbox",
    "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
    "transforms.outbox.table.field.event.id": "id",
    "transforms.outbox.table.field.event.key": "aggregate_id",
    "transforms.outbox.table.field.event.type": "event_type",
    "transforms.outbox.table.field.event.payload": "payload",
    "transforms.outbox.route.by.field": "event_type",
    "transforms.outbox.route.topic.replacement": "orders.v1.events",
    "errors.tolerance": "all",
    "errors.deadletterqueue.topic.name": "dlq.v1.notifications",
    "errors.deadletterqueue.context.headers.enable": "true"
  }
}
