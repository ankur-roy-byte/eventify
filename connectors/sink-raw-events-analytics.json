{
  "name": "sink-raw-events-analytics",
  "config": {
    "connector.class": "io.confluent.connect.elasticsearch.ElasticsearchSinkConnector",
    "tasks.max": "1",
    "topics": "dbz.orders.outbox_events,orders.v1.events,payments.v1.events,inventory.v1.events,risk.v1.fraud_alerts,web.v1.clickstream,analytics.v1.product_metrics,analytics.v1.web_path_metrics",
    "connection.url": "http://opensearch:9200",
    "key.ignore": "false",
    "schema.ignore": "false",
    "type.name": "_doc",
    "behavior.on.null.values": "ignore",
    "errors.tolerance": "all",
    "errors.deadletterqueue.topic.name": "dlq.v1.notifications",
    "errors.deadletterqueue.context.headers.enable": "true",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true"
  }
}
