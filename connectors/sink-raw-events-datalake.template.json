{
  "name": "sink-raw-events-datalake",
  "config": {
    "connector.class": "io.confluent.connect.s3.S3SinkConnector",
    "tasks.max": "1",
    "topics": "dbz.orders.outbox_events,orders.v1.events,payments.v1.events,inventory.v1.events,risk.v1.fraud_alerts,web.v1.clickstream,analytics.v1.product_metrics,analytics.v1.web_path_metrics",
    "s3.region": "us-east-1",
    "s3.bucket.name": "CHANGE_ME_BUCKET",
    "s3.part.size": "5242880",
    "flush.size": "1000",
    "storage.class": "io.confluent.connect.s3.storage.S3Storage",
    "format.class": "io.confluent.connect.s3.format.json.JsonFormat",
    "partitioner.class": "io.confluent.connect.storage.partitioner.TimeBasedPartitioner",
    "path.format": "'year'=YYYY/'month'=MM/'day'=dd/'hour'=HH",
    "locale": "en_US",
    "timezone": "UTC",
    "timestamp.extractor": "Record",
    "errors.tolerance": "all",
    "errors.deadletterqueue.topic.name": "dlq.v1.notifications",
    "errors.deadletterqueue.context.headers.enable": "true",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true"
  }
}
